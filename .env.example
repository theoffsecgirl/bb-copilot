# =============================================================
# bb-copilot — configuración del proveedor LLM
# Elige UNO y comenta los demás
# =============================================================

# --- OPCIÓN 1: Groq (recomendado — gratis, rápido) ---
# Regístrate en https://console.groq.com y crea una API key
OPENAI_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# --- OPCIÓN 2: Ollama (local, gratis, privado) ---
# brew install ollama && ollama pull llama3.1 && ollama serve
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.1

# --- OPCIÓN 3: OpenAI ---
# https://platform.openai.com/api-keys (requiere saldo en la cuenta API)
# OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXX
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# --- OPCIÓN 4: Anthropic Claude (via proxy OpenAI-compatible) ---
# OPENAI_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXX
# OPENAI_BASE_URL=https://api.anthropic.com/v1
# OPENAI_MODEL=claude-3-5-sonnet-20241022

# =============================================================
# Vault
# =============================================================
VAULT_PATH=./vault

# =============================================================
# Comportamiento del modelo
# =============================================================
BBCOPILOT_MAX_TOKENS=2048
BBCOPILOT_TEMPERATURE=0.2
