# bb-copilot — environment configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# --- Ollama (default, local, free) ---
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=llama3.1

# --- Groq (free tier, cloud) ---
# OPENAI_API_KEY=your-groq-api-key
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama3-70b-8192
# BBCOPILOT_MAX_CONTEXT_TOKENS=5000

# --- OpenAI ---
# OPENAI_API_KEY=sk-proj-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# --- Anthropic ---
# OPENAI_API_KEY=your-anthropic-api-key
# OPENAI_BASE_URL=https://api.anthropic.com/v1
# OPENAI_MODEL=claude-3-5-sonnet-20241022

# --- Optional settings ---
# BBCOPILOT_MAX_CONTEXT_TOKENS=8000
# BBCOPILOT_HISTORY_DIR=~/.bbcopilot/history
# BBCOPILOT_VAULT_DIR=./vault
