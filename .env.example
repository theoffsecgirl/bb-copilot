# =============================================================
# bb-copilot — configuración del proveedor LLM
# Elige UNO y comenta los demás
# =============================================================

# --- OPCIÓN 1: Ollama (por defecto — gratis, local, privado) ---
# brew install ollama && ollama pull llama3.1 && ollama serve
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=llama3.1

# --- OPCIÓN 2: Groq (gratis, nube — ojo: límite 6000 tokens en tier free) ---
# Regístrate en https://console.groq.com
# OPENAI_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXX
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
# BBCOPILOT_MAX_CONTEXT_TOKENS=5000  # necesario para no superar el límite

# --- OPCIÓN 3: OpenAI ---
# https://platform.openai.com/api-keys (requiere saldo en cuenta API)
# OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXX
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# --- OPCIÓN 4: Anthropic Claude (via proxy OpenAI-compatible) ---
# OPENAI_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXX
# OPENAI_BASE_URL=https://api.anthropic.com/v1
# OPENAI_MODEL=claude-3-5-sonnet-20241022

# =============================================================
# Vault
# =============================================================
VAULT_PATH=./vault
# Límite de tokens de contexto (0 = sin límite, usar con Ollama/OpenAI)
# Reducir a ~5000 si usas Groq free tier
BBCOPILOT_MAX_CONTEXT_TOKENS=0

# =============================================================
# Comportamiento del modelo
# =============================================================
BBCOPILOT_MAX_TOKENS=2048
BBCOPILOT_TEMPERATURE=0.2
